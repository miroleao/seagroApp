# ──────────────────────────────────────────────────────────────
# Arquivo: .env.local
# Copie este arquivo para .env.local e preencha com seus dados
# ──────────────────────────────────────────────────────────────

# Supabase — encontre em: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Usado apenas no servidor (não exposto ao browser)
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ID da fazenda SE Agropecuária (já inserido no seed)
NEXT_PUBLIC_FARM_ID=aaaaaaaa-0000-0000-0000-000000000001
